# Deployment secrets for local Docker registry + Watchtower redeploy.
# Copy to secrets/deploy.agent_visible_env and fill in values.
# NOT tracked in version control.
#
# These are the same values as MediaManager's deploy config — both
# projects push to the same private registry and are redeployed by
# the same Watchtower instance on the NAS.

# Private Docker registry (host:port)
REGISTRY=your-registry:port

# NAS IP address (used for Watchtower API calls)
NAS_IP=your-nas-ip

# Watchtower HTTP API port
WATCHTOWER_PORT=16001

# Watchtower HTTP API token (must match WATCHTOWER_HTTP_API_TOKEN in docker-compose on NAS)
WATCHTOWER_TOKEN=your-token
