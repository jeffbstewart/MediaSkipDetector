# MediaSkipDetector environment variables.
# Copy to secrets/.env and fill in values.
# NEVER commit .env files to source control.

# Path to the NAS media root directory (required)
# MEDIA_ROOT=/path/to/media

# Path to persistent data directory (fingerprint cache, etc.)
# Defaults to ./data if not set.
# DATA_DIR=/path/to/data

# Path to fpcalc binary (Chromaprint CLI tool)
# FPCALC_PATH=/usr/bin/fpcalc

# Path to ffmpeg binary (needed for credits detection tail audio extraction)
# ffprobe is found automatically alongside ffmpeg.
# FFMPEG_PATH=/usr/bin/ffmpeg

# ── Analysis tuning (see docs/TUNING.md for details) ──
# All have sensible defaults; only set if you need to override.
# MAX_FINGERPRINT_POINT_DIFFERENCES=6
# MAX_TIME_SKIP=3.5
# INVERTED_INDEX_SHIFT=2
# MIN_INTRO_DURATION=15
# MAX_INTRO_DURATION=120
# MAX_COMPARISON_CANDIDATES=7
# FINGERPRINT_LENGTH_SECONDS=120

# ── Credits detection tuning ──
# CREDITS_FINGERPRINT_SECONDS=300
# MIN_CREDITS_DURATION=15
# MAX_CREDITS_DURATION=300
